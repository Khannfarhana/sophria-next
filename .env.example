# Copy this file to .env and replace placeholder values.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret

# Supabase (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Supabase (server-side admin client)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Database (for migrations / direct Postgres access)
DATABASE_URL=postgres://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Mapbox — address autocomplete, map picker, route maps, distance pricing.
# Public (URL-restricted) access token from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=replace-with-mapbox-public-token

# Legacy / unused after the Mapbox migration.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=replace-with-google-maps-browser-key
